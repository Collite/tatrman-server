model db schema dbo
def table QZBOZI_DF { description: "Evidence všech artiklů (zboží) a jejich vlastností",
    primaryKey: ["IDZBOZI"],
    columns: [
        def column IDZBOZI { type: int, isKey: true, description: "Unikátní identifikátor artiklu" },
        def column KOD_ZBOZI { type: text, optional: true, indexed: true, description: "Unikátní kód artiklu" },
        def column NAZEV_ZBOZI { type: text, optional: true, description: "Obchodní název artiklu" },
        def column IDSKUPZBOZI { type: int, optional: true, indexed: true, description: "FK na nadřazený produkt" },
        def column IDXXPODSKUPZBOZI { type: int, optional: true, indexed: true, description: "FK na nadřazený podprodukt" },
        def column VLPLATI { type: int, optional: true, description: "Příznak platnosti (0 = neaktivní, 1 = aktivní)" }
    ],
    indices: [
        def index IX_QZBOZI_KOD { columns: ["KOD_ZBOZI"] },
        def index IX_QZBOZI_SKUPINA_PODSKUPINA { columns: ["IDSKUPZBOZI", "IDXXPODSKUPZBOZI"] }
    ],
    constraints: [
        def constraint UQ_QZBOZI_KOD { type: unique, columns: ["KOD_ZBOZI"] }
    ]
}

def table QSKUPZBOZI_DF { description: "Evidence produktů a jejich vlastností",
    primaryKey: ["IDSKUPZBOZI"],
    columns: [
        def column IDSKUPZBOZI { type: int, isKey: true, description: "Unikátní identifikátor produktu" },
        def column KOD_SKUPZBOZI { type: text, optional: true, indexed: true, description: "Unikátní kód produktu" },
        def column NAZEV_SKUPZBOZI { type: text, optional: true, description: "Obchodní název produktu" }
    ],
    indices: [
        def index IX_QSKUPZBOZI_KOD { columns: ["KOD_SKUPZBOZI"] }
    ],
    constraints: [
        def constraint UQ_QSKUPZBOZI_KOD { type: unique, columns: ["KOD_SKUPZBOZI"] }
    ]
}

def table QXXPODSKUPZBOZI { description: "Evidence podproduktů a jejich vlastností",
    primaryKey: ["IDXXPODSKUPZBOZI"],
    columns: [
        def column IDXXPODSKUPZBOZI { type: int, isKey: true, description: "Unikátní identifikátor podproduktu" },
        def column KOD_PODSKUPZBOZI { type: text, optional: true, indexed: true, description: "Unikátní kód podproduktu" },
        def column NAZEV_PODSKUPZBOZI { type: text, optional: true, description: "Obchodní název podproduktu" },
        def column IDSKUPZBOZI { type: int, optional: true, indexed: true, description: "FK na nadřazený produkt" }
    ],
    indices: [
        def index IX_QXXPODSKUPZBOZI_KOD { columns: ["KOD_PODSKUPZBOZI"] }
    ]
}

def table QCENSKUP_DF { description: "Evidence obchodních kanálů a jejich vlastností",
    primaryKey: ["IDCENSKUP"],
    columns: [
        def column IDCENSKUP { type: int, isKey: true, description: "Unikátní identifikátor obchodního kanálu" },
        def column KOD_CENSKUP { type: text, optional: true, indexed: true, description: "Unikátní kód obchodního kanálu" },
        def column NAZEV_CENSKUP { type: text, optional: true, description: "Název obchodního kanálu" },
        def column IDSKUPZNACZBOZI { type: int, optional: true, indexed: true, description: "FK na tržní skupinu" }
    ],
    indices: [
        def index IX_QCENSKUP_KOD { columns: ["KOD_CENSKUP"] }
    ],
    constraints: [
        def constraint UQ_QCENSKUP_KOD { type: unique, columns: ["KOD_CENSKUP"] }
    ]
}

def table QSKUPZNACZBOZI_DF { description: "Evidence tržních skupin a jejich vlastností",
    primaryKey: ["IDSKUPZNACZBOZI"],
    columns: [
        def column IDSKUPZNACZBOZI { type: int, isKey: true, description: "Unikátní identifikátor tržní skupiny" },
        def column KOD_SKUPZNACZBOZI { type: text, optional: true, indexed: true, description: "Unikátní kód tržní skupiny" },
        def column NAZEV_SKUPZNACZBOZI { type: text, optional: true, description: "Název tržní skupiny" }
    ],
    indices: [
        def index IX_QSKUPZNACZBOZI_KOD { columns: ["KOD_SKUPZNACZBOZI"] }
    ]
}

def table QSUBJEKT { description: "Evidence zákazníků (subjektů) a jejich vlastností",
    primaryKey: ["IDSUBJEKT"],
    columns: [
        def column IDSUBJEKT { type: int, isKey: true, description: "Unikátní identifikátor subjektu" },
        def column ICO { type: text, optional: true, indexed: true, description: "IČO subjektu" },
        def column NAZEV_SUBJEKT { type: text, optional: true, description: "Obchodní název subjektu" },
        def column IDCENSKUP { type: int, optional: true, indexed: true, description: "FK na obchodní kanál" }
    ],
    indices: [
        def index IX_QSUBJEKT_ICO { columns: ["ICO"] }
    ],
    constraints: [
        def constraint UQ_QSUBJEKT_ICO { type: unique, columns: ["ICO"] }
    ]
}

def fk fk_artikl_produkt { description: "Artikl odkazuje na nadřazený produkt",
    from: [db.dbo.QZBOZI_DF.IDSKUPZBOZI], to: [db.dbo.QSKUPZBOZI_DF.IDSKUPZBOZI]
}

def fk fk_artikl_podprodukt { description: "Artikl odkazuje na nadřazený podprodukt",
    from: [db.dbo.QZBOZI_DF.IDXXPODSKUPZBOZI], to: [db.dbo.QXXPODSKUPZBOZI.IDXXPODSKUPZBOZI]
}

def fk fk_podprodukt_produkt { description: "Podprodukt odkazuje na nadřazený produkt",
    from: [db.dbo.QXXPODSKUPZBOZI.IDSKUPZBOZI], to: [db.dbo.QSKUPZBOZI_DF.IDSKUPZBOZI]
}

def fk fk_kanál_tržní_skupina { description: "Obchodní kanál odkazuje na tržní skupinu",
    from: [db.dbo.QCENSKUP_DF.IDSKUPZNACZBOZI], to: [db.dbo.QSKUPZNACZBOZI_DF.IDSKUPZNACZBOZI]
}

def fk fk_subjekt_kanál { description: "Subjekt odkazuje na obchodní kanál",
    from: [db.dbo.QSUBJEKT.IDCENSKUP], to: [db.dbo.QCENSKUP_DF.IDCENSKUP]
}

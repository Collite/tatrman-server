package samples.v2_1

model binding
// podprodukt: no inline mapping — covered explicitly
def er2db_entity podprodukt { entity: er.entity.podprodukt, target: { table: db.dbo.QXXPODSKUPZBOZI } }

// obchodní_kanál: no inline mapping
def er2db_entity obchodní_kanál { entity: er.entity.obchodní_kanál, target: { table: db.dbo.QCENSKUP_DF } }

// tržní_skupina: no inline mapping
def er2db_entity tržní_skupina { entity: er.entity.tržní_skupina, target: { table: db.dbo.QSKUPZNACZBOZI_DF } }

// subjekt: no inline mapping
def er2db_entity subjekt { entity: er.entity.subjekt, target: { table: db.dbo.QSUBJEKT } }

// podprodukt attributes
def er2db_attribute podprodukt.id_podproduktu { attribute: er.entity.podprodukt.id_podproduktu, target: { column: db.dbo.QXXPODSKUPZBOZI.IDXXPODSKUPZBOZI } }
def er2db_attribute podprodukt.id_produktu { attribute: er.entity.podprodukt.id_produktu, target: { column: db.dbo.QXXPODSKUPZBOZI.IDSKUPZBOZI } }

// obchodní_kanál attributes
def er2db_attribute obchodní_kanál.id_kanálu { attribute: er.entity.obchodní_kanál.id_kanálu, target: { column: db.dbo.QCENSKUP_DF.IDCENSKUP } }
def er2db_attribute obchodní_kanál.id_tržní_skupiny { attribute: er.entity.obchodní_kanál.id_tržní_skupiny, target: { column: db.dbo.QCENSKUP_DF.IDSKUPZNACZBOZI } }

// tržní_skupina attributes
def er2db_attribute tržní_skupina.id_tržní_skupiny { attribute: er.entity.tržní_skupina.id_tržní_skupiny, target: { column: db.dbo.QSKUPZNACZBOZI_DF.IDSKUPZNACZBOZI } }

// subjekt attributes
def er2db_attribute subjekt.id_subjektu { attribute: er.entity.subjekt.id_subjektu, target: { column: db.dbo.QSUBJEKT.IDSUBJEKT } }
def er2db_attribute subjekt.id_kanálu { attribute: er.entity.subjekt.id_kanálu, target: { column: db.dbo.QSUBJEKT.IDCENSKUP } }

// podprodukt -> produkt relation (no inline mapping — explicit here)
def er2db_relation podprodukt_produkt { relation: er.entity.podprodukt_produkt, fk: db.dbo.fk_podprodukt_produkt }

// obchodní kanál -> tržní skupina (no inline mapping)

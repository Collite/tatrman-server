model er

// RG-P3.S0.T2 (f) — an invalid semantics block: `event_date` declares a
// `period:` reference to an entity that does not exist. ttr-semantics flags this
// (TTR-SEM-2xx) as a load issue; Veles must still SERVE the object (its
// structural detail) but WITHOUT the unresolved semantics, and surface the load
// warning through the status/messages path — degrade, never crash.

def entity Ledger {
    attributes: [
        def attribute booked { type: date, semantics { role: event_date, period: NoSuchPeriod } }
    ]
}

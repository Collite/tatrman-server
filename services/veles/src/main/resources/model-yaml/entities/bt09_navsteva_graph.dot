  denni_vykaz_oz -> uzivatel;
  navsteva_zakaznika -> uzivatel;
  navsteva_zakaznika -> denni_vykaz_oz;
  navsteva_zakaznika -> dodaci_misto;
  artikl_navstevy_zakaznika -> navsteva_zakaznika;
  artikl_navstevy_zakaznika -> artikl;
  artikl_navstevy_zakaznika -> podprodukt;
  ukol_navstevy_zakaznika -> navsteva_zakaznika;
  podnet_navstevy_zakaznika -> navsteva_zakaznika;
  podnet_navstevy_zakaznika -> produkt;

digraph BT02_Artikl {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  produkt [label="produkt"];
  podprodukt [label="podprodukt"];
  cenova_skupina_artiklu [label="cenová_skupina_artiklu"];
  artikl [label="artikl"];
  zasoba_artiklu [label="zásoba_artiklu"];
  // Externí entity (z jiných BT)
  uzivatel [label="uživatel\n(bt01)", style="rounded,filled,dashed", fillcolor="#e0e0e0"];

  podprodukt -> produkt;
  podprodukt -> uzivatel;
  artikl -> produkt;
  artikl -> podprodukt;
  artikl -> cenova_skupina_artiklu;
  zasoba_artiklu -> artikl;
}

digraph BT20_Ucetnictvi {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  ucetni_obdobi [label="účetní_období"];
  ukazatel_mu [label="ukazatel_manažerského_účetnictví"];
  ucetni_stredisko [label="účetní_středisko"];
  ucet_ucetni_osnovy [label="účet_účetní_osnovy"];
  hodnoty_mu [label="hodnoty_manažerského_účetnictví"];
  typ_dokladu [label="typ_dokladu"];
  ucetni_doklad [label="účetní_doklad"];
  ucetni_zapis [label="účetní_zápis"];

  ucetni_stredisko -> ukazatel_mu;
  hodnoty_mu -> ukazatel_mu;
  hodnoty_mu -> ucetni_obdobi;
  ucetni_zapis -> ucetni_stredisko;
  ucetni_zapis -> ucetni_obdobi;
  ucetni_zapis -> ucet_ucetni_osnovy;
  ucetni_zapis -> ucetni_doklad [label="IDHDOK"];
  ucetni_zapis -> ucetni_doklad [label="IDSDOK"];
  ucetni_doklad -> typ_dokladu;
}

digraph BT12_Vyteznost {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  vyteznost_regalu [label="výtěžnost_regálu"];
  vyteznost_regalu_kanal [label="výtěžnost_regálu_kanál"];
  // Externí entity (z jiných BT)
  obchodni_kanal [label="obchodní_kanál", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  produkt [label="produkt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  podprodukt [label="podprodukt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  artikl [label="artikl", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  dodaci_misto [label="dodací_místo", fillcolor="#e0e0e0", style="rounded,filled,dashed"];

  vyteznost_regalu -> dodaci_misto;
  vyteznost_regalu -> obchodni_kanal;
  vyteznost_regalu -> produkt;
  vyteznost_regalu -> podprodukt;
  vyteznost_regalu -> artikl;

  vyteznost_regalu_kanal -> obchodni_kanal;
  vyteznost_regalu_kanal -> artikl;
}

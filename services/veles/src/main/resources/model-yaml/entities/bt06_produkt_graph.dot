digraph BT06_Produkt {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  produkt_pro_firmu [label="produkt_pro_firmu"];
  podprodukt_pro_firmu [label="podprodukt_pro_firmu"];
  produkt_pro_trzni_skupinu [label="produkt_pro_tržní_skupinu"];
  produkt_pro_obchodni_kanal [label="produkt_pro_obchodní_kanál"];
  podprodukt_pro_trzni_skupinu [label="podprodukt_pro_tržní_skupinu"];
  podprodukt_pro_obchodni_kanal [label="podprodukt_pro_obchodní_kanál"];
  artikl_pro_trzni_skupinu [label="artikl_pro_tržní_skupinu"];
  artikl_pro_obchodni_kanal [label="artikl_pro_obchodní_kanál"];
  // Externí entity (z jiných BT)
  produkt [label="produkt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  podprodukt [label="podprodukt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  artikl [label="artikl", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  trzni_skupina [label="tržní_skupina", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  obchodni_kanal [label="obchodní_kanál", fillcolor="#e0e0e0", style="rounded,filled,dashed"];

  produkt_pro_firmu -> trzni_skupina;
  produkt_pro_firmu -> produkt;
  podprodukt_pro_firmu -> trzni_skupina;
  podprodukt_pro_firmu -> podprodukt;
  produkt_pro_trzni_skupinu -> trzni_skupina;
  produkt_pro_trzni_skupinu -> produkt;
  produkt_pro_obchodni_kanal -> obchodni_kanal;
  produkt_pro_obchodni_kanal -> produkt;
  podprodukt_pro_trzni_skupinu -> trzni_skupina;
  podprodukt_pro_trzni_skupinu -> podprodukt;
  podprodukt_pro_obchodni_kanal -> obchodni_kanal;
  podprodukt_pro_obchodni_kanal -> podprodukt;
  artikl_pro_trzni_skupinu -> trzni_skupina;
  artikl_pro_trzni_skupinu -> artikl;
  artikl_pro_obchodni_kanal -> obchodni_kanal;
  artikl_pro_obchodni_kanal -> artikl;
}

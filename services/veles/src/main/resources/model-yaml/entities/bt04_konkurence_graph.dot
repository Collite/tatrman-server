digraph BT04_Konkurence {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  konkurencni_dodavatel [label="konkurenční_dodavatel"];
  konkurencni_znacka [label="konkurenční_značka"];
  typ_informace_o_konkurenci [label="typ_informace_o_konkurenci"];
  informace_ke_konkurenci [label="informace_ke_konkurenci"];
  // Externí entity (z jiných BT)
  trzni_skupina [label="tržní_skupina", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  obchodni_kanal [label="obchodní_kanál", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  produkt [label="produkt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  podprodukt [label="podprodukt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];

  informace_ke_konkurenci -> konkurencni_dodavatel;
  informace_ke_konkurenci -> konkurencni_znacka;
  informace_ke_konkurenci -> trzni_skupina;
  informace_ke_konkurenci -> obchodni_kanal;
  informace_ke_konkurenci -> produkt;
  informace_ke_konkurenci -> podprodukt;
  informace_ke_konkurenci -> typ_informace_o_konkurenci;
}

digraph BT10_Obchodni_doklady {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  zakazka [label="zakázka"];
  zakazka_slozka [label="zakázka_složka"];
  vratka [label="vratka"];
  vratka_slozka [label="vratka_složka"];
  faktura [label="faktura"];
  faktura_slozka [label="faktura_složka"];
  dobropis [label="dobropis"];
  dobropis_slozka [label="dobropis_složka"];
  reklamace [label="reklamace"];
  reklamace_slozka [label="reklamace_složka"];
  tok_dokladu [label="tok_dokladů"];
  
  // Externí entity (z jiných BT)
  dodaci_misto [label="dodací_místo", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  subjekt [label="subjekt", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  artikl [label="artikl", fillcolor="#e0e0e0", style="rounded,filled,dashed"];
  prodejni_akce [label="prodejní_akce", fillcolor="#e0e0e0", style="rounded,filled,dashed"];

  zakazka -> dodaci_misto;
  zakazka_slozka -> zakazka;
  zakazka_slozka -> artikl;
  zakazka_slozka -> prodejni_akce;
  
  vratka -> dodaci_misto;
  vratka_slozka -> vratka;
  vratka_slozka -> artikl;
  
  faktura -> subjekt;
  faktura_slozka -> faktura;
  faktura_slozka -> artikl;
  
  dobropis -> subjekt;
  dobropis_slozka -> dobropis;
  dobropis_slozka -> artikl;

  reklamace -> dodaci_misto;
  reklamace_slozka -> reklamace;
  reklamace_slozka -> artikl;

  tok_dokladu -> zakazka [label="předchůdce/následník"];
  tok_dokladu -> vratka [label="předchůdce/následník"];
  tok_dokladu -> faktura [label="předchůdce/následník"];
  tok_dokladu -> dobropis [label="předchůdce/následník"];
  tok_dokladu -> reklamace [label="předchůdce/následník"];
}

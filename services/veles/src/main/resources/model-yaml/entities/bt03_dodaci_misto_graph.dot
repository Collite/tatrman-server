digraph BT03_Dodaci_Misto {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#f4f4f4", fontname="Segoe UI"];

  trzni_skupina [label="tržní_skupina"];
  obchodni_kanal [label="obchodní_kanál"];
  typ_dodaciho_mista [label="typ_dodacího_místa"];

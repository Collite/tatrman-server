  osoba_dodaciho_mista [label="osoba_dodacího_místa"];
  prodejni_akce [label="prodejní_akce"];
  cenova_politika [label="cenová_politika"];
  // Externí entity (z jiných BT)
  uzivatel [label="uživatel\n(bt01)", style="rounded,filled,dashed", fillcolor="#e0e0e0"];
  artikl [label="artikl\n(bt02)", style="rounded,filled,dashed", fillcolor="#e0e0e0"];
  cenova_skupina_artiklu [label="cenová_skupina_artiklu\n(bt02)", style="rounded,filled,dashed", fillcolor="#e0e0e0"];

  podprodukt [label="podprodukt\n(bt02)", style="rounded,filled,dashed", fillcolor="#e0e0e0"];

  obchodni_kanal -> trzni_skupina;
  obchodni_kanal -> uzivatel;
  obchodni_vztah -> subjekt;
  obchodni_vztah -> obchodni_kanal;
  typ_dodaciho_mista -> obchodni_kanal;
  platnost_dm_v_tdm -> dodaci_misto;
  platnost_dm_v_tdm -> typ_dodaciho_mista;
  dodaci_misto -> subjekt;
  dodaci_misto -> uzivatel;
  osoba_dodaciho_mista -> dodaci_misto;
  cenova_politika -> artikl;
  cenova_politika -> cenova_skupina_artiklu;
  cenova_politika -> subjekt;
  cenova_politika -> obchodni_kanal;
  cenova_politika -> produkt;
  cenova_politika -> podprodukt;
}

        def column DTZDANITPLN { type: date, optional: true, description: "Datum plnění reklamace", },
        def column DTVYSTAVENO { type: date, optional: true, description: "Datum vystavení reklamace", },
        def column VLSTAVHDOK { type: int, optional: true, description: """Stav reklamace:
 0 = Pořízeno
 1 = K ověření OA
 2 = K ověření OZ
 3 = Ověřeno OZ

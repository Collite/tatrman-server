package obchodni_doklady
def table QHDOK_FAV_DF { description: """Hlavička dobropisu - obchodní doklad pro vrácení peněz zákazníkovi.
""", primaryKey: ["IDHDOK"],
    columns: [
        def column IDHDOK { type: int, isKey: true, description: "Unikátní identifikátor dobropisu", },
        def column CIS_DOK { type: text, optional: true, description: "Číslo dobropisu", },
        def column ZAK_HDOK { type: text, optional: true, description: "Vazba na číslo vratky", },
        def column IDSUBJEKT { type: int, optional: true, description: "Vazba na zákazníka (subjekt)", },
        def column DTZDANITPLN { type: date, optional: true, description: "Datum plnění dobropisu", },
        def column DTVYSTAVENO { type: date, optional: true, description: "Datum vystavení dobropisu", },
        def column DTSPLATNO { type: date, optional: true, description: "Datum splatnosti dobropisu", },
        def column HDKUHRADEVAL { type: text, optional: true, description: "Celková hodnota dobropisu v Kč (záporná částka)", },
        def column VLSTAVHDOK { type: int, optional: true, description: """Stav dobropisu:
 0 = Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno
""", },
    ]
}

def table QHDOK_ZAK_DF { description: """Hlavička reklamace - obchodní doklad pro reklamaci.

        def attribute datum_plnění_předchůdce { type: datetime, optional: true, description: "Datum plnění předchozího dokladu", binding: DTZDANITPLNP, },
        def attribute stav_předchůdce { type: text, optional: true, description: "Stav předchozího dokladu", binding: STAVP, },
        def attribute id_následníka { type: int, optional: true, description: "Identifikace následného dokladu (např. Faktura)", binding: IDHDOKN, },
        def attribute číslo_následníka { type: text, optional: true, description: "Číslo následného dokladu", binding: CIS_DOKN, },
        def attribute typ_následníka { type: text, optional: true, description: "Typ následného dokladu (např. Faktura, Dobropis)", binding: NAZEV_TYPDOKN, },
        def attribute datum_plnění_následníka { type: datetime, optional: true, description: "Datum plnění následného dokladu", binding: DTZDANITPLNN, },
        def attribute stav_následníka { type: text, optional: true, description: "Stav následného dokladu", binding: STAVN, },
    ]
}


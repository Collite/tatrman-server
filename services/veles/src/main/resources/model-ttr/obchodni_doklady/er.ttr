package obchodni_doklady
def entity dobropis { description: """Hlavička dobropisu - obchodní doklad pro vrácení peněz zákazníkovi.
""", binding: { target: { sqlQuery: db.query.dobropis__filter } },
    attributes: [
        def attribute id_dobropisu { type: int, isKey: true, description: "Unikátní identifikátor dobropisu", binding: IDHDOK, },
        def attribute číslo_dobropisu { type: text, optional: true, description: "Číslo dobropisu", binding: CIS_DOK, },
        def attribute vratka { type: text, optional: true, description: "Vazba na číslo vratky", binding: ZAK_HDOK, },
        def attribute id_subjektu { type: int, optional: true, description: "Vazba na zákazníka (subjekt)", binding: IDSUBJEKT, },
        def attribute datum_plnění { type: datetime, optional: true, description: "Datum plnění dobropisu", binding: DTZDANITPLN, },
        def attribute datum_vystavení { type: datetime, optional: true, description: "Datum vystavení dobropisu", binding: DTVYSTAVENO, },
        def attribute datum_splatnosti { type: datetime, optional: true, description: "Datum splatnosti dobropisu", binding: DTSPLATNO, },
        def attribute hodnota_dobropisu { type: text, optional: true, description: "Celková hodnota dobropisu v Kč (záporná částka)", binding: HDKUHRADEVAL, },
        def attribute stav_dobropisu { type: int, optional: true, description: """Stav dobropisu:
 0 = Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno
""", valueLabels: { "0": { cs: """Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno""" } }, binding: VLSTAVHDOK, },
    ]
}

def entity dobropis_složka { description: """Složka (položka) dobropisu - jednotlivé artikly na dobropisu.
⚠ Tabulka QZBOZSDOK je sdílená pro složky všech typů dokladů.
Příslušnost ke konkrétnímu dokladu se určuje JOINem na hlavičku (IDHDOK).
Pravidlo: Vždy použij JOIN na příslušnou hlavičku dokladu, nikdy nedotazuj QZBOZSDOK samostatně.
""", binding: { target: { table: db.dbo.QZBOZSDOK } },
    attributes: [
        def attribute id_složky_dobropisu { type: int, isKey: true, description: "Unikátní identifikátor složky dobropisu", binding: IDSDOK, },
        def attribute id_dobropisu { type: int, optional: true, description: "Vazba na hlavičku dobropisu", binding: IDHDOK, },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", binding: IDZBOZI, },
        def attribute množství { type: float, optional: true, description: "Množství kusů na dobropisu", binding: MNCELKEMPOCET, },
        def attribute cena_za_kus { type: text, optional: true, description: "Cena za měrnou jednotku", binding: HDJCENAVAL, },
        def attribute celková_cena { type: text, optional: true, description: "Celková cena položky", binding: HDCCENAVAL, },
    ]
}


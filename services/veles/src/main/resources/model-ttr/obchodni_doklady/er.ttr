def relation dobropis_slozka_artikl { description: "Složka dobropisu obsahuje konkrétní artikl", from: er.entity.dobropis_složka, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.dobropis_slozka_artikl,
}

def relation dobropis_slozka_dobropis { description: "Složka dobropisu patří k dobropisu", from: er.entity.dobropis_složka, to: er.entity.dobropis, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis_složka.id_dobropisu, to: er.entity.dobropis.id_dobropisu }], binding: db.dbo.dobropis_slozka_dobropis,
}

def relation dobropis_subjekt { description: "Dobropis patří k zákazníkovi (subjektu)", from: er.entity.dobropis, to: er.entity.subjekt, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.dobropis_subjekt,
}

def relation faktura_slozka_artikl { description: "Složka faktury obsahuje konkrétní artikl", from: er.entity.faktura_složka, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.faktura_slozka_artikl,
}

def relation faktura_slozka_faktura { description: "Složka faktury patří k faktuře", from: er.entity.faktura_složka, to: er.entity.faktura, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis_složka.id_dobropisu, to: er.entity.dobropis.id_dobropisu }], binding: db.dbo.faktura_slozka_faktura,
}

def relation faktura_subjekt { description: "Faktura patří k zákazníkovi (subjektu)", from: er.entity.faktura, to: er.entity.subjekt, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.faktura_subjekt,
}

def relation reklamace_dodaci_misto { description: "Reklamace patří k dodacímu místu", from: er.entity.reklamace, to: er.entity.dodací_místo, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.reklamace_dodaci_misto,
}

def relation reklamace_slozka_artikl { description: "Složka reklamace obsahuje konkrétní artikl", from: er.entity.reklamace_složka, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.reklamace_slozka_artikl,
}

def relation reklamace_slozka_reklamace { description: "Složka reklamace patří k reklamaci", from: er.entity.reklamace_složka, to: er.entity.reklamace, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.reklamace_složka.id_reklamace, to: er.entity.reklamace.id_reklamace }], binding: db.dbo.reklamace_slozka_reklamace,
}

def relation tok_dokladu_naslednik_dobropis { description: "Následník v toku dokladů je dobropis. Disambiguace: cílová entita filtrována WHERE TYP_DOK='FVU' AND HDKUHRADEVAL<0.", from: er.entity.tok_dokladů, to: er.entity.dobropis, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.tok_dokladů.id_následníka, to: er.entity.dobropis.id_dobropisu }], binding: db.dbo.tok_dokladu_naslednik_dobropis,
}

def relation tok_dokladu_naslednik_faktura { description: "Následník v toku dokladů je faktura. Disambiguace: cílová entita filtrována WHERE TYP_DOK='FVU' AND HDKUHRADEVAL>=0.", from: er.entity.tok_dokladů, to: er.entity.faktura, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.tok_dokladů.id_následníka, to: er.entity.dobropis.id_dobropisu }], binding: db.dbo.tok_dokladu_naslednik_faktura,
}

def relation tok_dokladu_naslednik_reklamace { description: "Následník v toku dokladů je reklamace. Disambiguace: cílová entita filtrována WHERE TYP_DOK='PDO'.", from: er.entity.tok_dokladů, to: er.entity.reklamace, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.tok_dokladů.id_následníka, to: er.entity.reklamace.id_reklamace }], binding: db.dbo.tok_dokladu_naslednik_reklamace,
}

def relation tok_dokladu_naslednik_vratka { description: "Následník v toku dokladů je vratka. Disambiguace: cílová entita filtrována WHERE TYP_DOK='POB' AND HDKUHRADEVAL<0.", from: er.entity.tok_dokladů, to: er.entity.vratka, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.tok_dokladů.id_následníka, to: er.entity.reklamace.id_reklamace }], binding: db.dbo.tok_dokladu_naslednik_vratka,
}

def relation tok_dokladu_naslednik_zakazka { description: "Následník v toku dokladů je zakázka. Disambiguace: cílová entita filtrována WHERE TYP_DOK='POB' AND HDKUHRADEVAL>=0.", from: er.entity.tok_dokladů, to: er.entity.zakázka, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.tok_dokladů.id_následníka, to: er.entity.reklamace.id_reklamace }], binding: db.dbo.tok_dokladu_naslednik_zakazka,
}


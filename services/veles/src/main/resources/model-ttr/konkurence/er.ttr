def relation informace_ke_konkurenci_konkurencni_dodavatel { description: "Informace ke konkurenci odkazuje na konkurenčního dodavatele", from: er.entity.informace_ke_konkurenci, to: er.entity.konkurenční_dodavatel, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.informace_ke_konkurenci.id_konkurenčního_dodavatele, to: er.entity.konkurenční_značka.id_konkurenční_značky }], binding: db.dbo.informace_ke_konkurenci_konkurencni_dodavatel,
}

def relation informace_ke_konkurenci_konkurencni_znacka { description: "Informace ke konkurenci odkazuje na konkurenční značku", from: er.entity.informace_ke_konkurenci, to: er.entity.konkurenční_značka, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.informace_ke_konkurenci.id_konkurenční_značky, to: er.entity.konkurenční_značka.id_konkurenční_značky }], binding: db.dbo.informace_ke_konkurenci_konkurencni_znacka,
}

def relation informace_ke_konkurenci_obchodni_kanal { description: "Informace ke konkurenci odkazuje na obchodní kanál", from: er.entity.informace_ke_konkurenci, to: er.entity.obchodní_kanál, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.informace_ke_konkurenci_obchodni_kanal,
}

def relation informace_ke_konkurenci_podprodukt { description: "Informace ke konkurenci odkazuje na podprodukt", from: er.entity.informace_ke_konkurenci, to: er.entity.podprodukt, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.informace_ke_konkurenci_podprodukt,
}

def relation informace_ke_konkurenci_produkt { description: "Informace ke konkurenci odkazuje na produkt", from: er.entity.informace_ke_konkurenci, to: er.entity.produkt, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.informace_ke_konkurenci_produkt,
}

def relation informace_ke_konkurenci_trzni_skupina { description: "Informace ke konkurenci odkazuje na tržní skupinu", from: er.entity.informace_ke_konkurenci, to: er.entity.tržní_skupina, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.informace_ke_konkurenci_trzni_skupina,
}

def relation informace_ke_konkurenci_typ_informace { description: "Informace ke konkurenci používá typ informace o konkurenci", from: er.entity.informace_ke_konkurenci, to: er.entity.typ_informace_o_konkurenci, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.informace_ke_konkurenci.typ_informace, to: er.entity.typ_informace_o_konkurenci.typ_informace }, { from: er.entity.informace_ke_konkurenci.vlastnost_informace, to: er.entity.typ_informace_o_konkurenci.vlastnost_informace }, { from: er.entity.informace_ke_konkurenci.oblast_informace, to: er.entity.typ_informace_o_konkurenci.oblast_informace }], binding: db.dbo.informace_ke_konkurenci_typ_informace,
}


def relation artikl_pro_obchodni_kanal_artikl { description: "Záznam artiklu v obchodním kanálu je navázán na artikl", from: er.entity.artikl_pro_obchodní_kanál, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, binding: db.dbo.artikl_pro_obchodni_kanal_artikl,

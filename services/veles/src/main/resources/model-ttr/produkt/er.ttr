package produkt
def entity artikl_pro_obchodní_kanál { description: """
Artikl přiřazený k obchodnímu kanálu.
""", binding: { target: { table: db.dbo.QXXLISTING } },
    attributes: [
        def attribute id_artiklu_pro_obchodní_kanál { type: int, isKey: true, description: "Unikátní identifikátor artiklu přiřazeného k obchodnímu kanálu", binding: IDXXLISTING, },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", binding: IDZBOZI, },
        def attribute id_obchodního_kanálu { type: int, optional: true, description: "Vazba na obchodní kanál", binding: IDCENSKUP, },
        def attribute význam_zadaný { type: int, optional: true, description: "Zadaný význam artiklu v rámci obchodního kanálu", binding: VLVYZNAM_Z, },
    ]
}

def entity artikl_pro_tržní_skupinu { description: """

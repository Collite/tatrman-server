def entity podprodukt_pro_firmu { description: """
Podprodukt přiřazený k firmě za všechny země.
""", binding: { target: { sqlQuery: db.query.podprodukt_pro_firmu__filter } },
    attributes: [
        def attribute id_podproduktu_pro_firmu { type: int, isKey: true, description: "Unikátní identifikátor podproduktu přiřazeného k firmě", binding: IDXXMEZABC, },
        def attribute id_podproduktu { type: int, optional: true, description: "Vazba na podprodukt", binding: IDXXPODSKUPZBOZI, },
        def attribute id_tržní_skupiny { type: int, optional: true, description: "Vazba na tržní skupinu", binding: IDSKUPZNACZBOZI, },
        def attribute pořadí_spočtené { type: int, optional: true, description: "Spočtené pořadí pro zobrazení podproduktu v rámci firmy", binding: PORADI_S, },
        def attribute pořadí_zadané { type: int, optional: true, description: "Zadané pořadí pro zobrazení podproduktu v rámci firmy", binding: PORADI, },
        def attribute pořadí_finální { type: int, optional: true, description: "Finální pořadí pro zobrazení podproduktu v rámci firmy. Pro řazení vždy použij tento sloupec (ne PORADI_S ani PORADI).", binding: PORADI_F, },
        def attribute význam_spočtený { type: int, optional: true, description: "Spočtený význam podproduktu v rámci firmy", binding: VLVYZNAM_S, },
        def attribute význam_zadaný { type: int, optional: true, description: "Zadaný význam podproduktu v rámci firmy", binding: VLVYZNAM_Z, },
        def attribute význam_finální { type: int, optional: true, description: "Finální význam podproduktu v rámci firmy", binding: VLVYZNAM_F, },
        def attribute normativ_tržby_spočtený { type: text, optional: true, description: "Normativní podíl tržby spočtený. Hodnota v procentech (25.00 = 25 %).", valueLabels: { "00": { cs: "25 %" } }, binding: HDNORMATIV_TRZBY_S, },
        def attribute normativ_tržby_zadaný { type: text, optional: true, description: "Normativní podíl tržby zadaný. Hodnota v procentech (25.00 = 25 %).", valueLabels: { "00": { cs: "25 %" } }, binding: HDNORMATIV_TRZBY_Z, },
        def attribute normativ_tržby_finální { type: text, optional: true, description: "Normativní podíl tržby finální. Hodnota v procentech (25.00 = 25 %).", valueLabels: { "00": { cs: "25 %" } }, binding: HDNORMATIV_TRZBY_F, },
    ]
}


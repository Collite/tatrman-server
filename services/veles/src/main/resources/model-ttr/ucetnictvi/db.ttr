package ucetnictvi
def table QSDOK { description: """Složky obchodních dokladů – řádky dokladů s vazbou na hlavičku, zboží a účetní období.
""", primaryKey: ["IDSDOK"],
    columns: [
        def column IDSDOK { type: int, isKey: true, description: "Unikátní identifikátor složky dokladu", },
        def column IDHDOK { type: int, optional: true, description: "FK na hlavičku dokladu", },
        def column IDTYPDOK { type: int, optional: true, description: "FK na typ dokladu", },
        def column IDSUBJEKT { type: int, optional: true, description: "FK na subjekt (odběratel/dodavatel)", },
        def column CIS_DOK { type: text, optional: true, description: "Číslo dokladu", },
        def column DTZDANITPLN { type: datetime, optional: true, description: "Datum uskutečnění zdanitelného plnění (DUZP)", },
        def column TEXTPOZN { type: text, optional: true, description: "Text hlavičky / poznámka dokladu", },
        def column ZAK_SDOK { type: text, optional: true, description: "Číslo zakázky na složce dokladu", },
        def column PORADI_DOK { type: int, optional: true, description: "Pořadí složky v rámci dokladu", },
        def column VLTYP_SLOZ { type: int, optional: true, description: "Typ složky (1=zboží, 2=služba, 3=ostatní, 9=poplatek)", },
        def column KOD_POHYB { type: text, optional: true, description: "Kód pohybu složky (např. FV = Faktura vydaná)", },
        def column SLOZKA_IDENT { type: text, optional: true, description: "Kód složky (identifikátor artiklu/zboží)", },
        def column NAZEV_ZBOZI { type: text, optional: true, description: "Název složky (název zboží/služby)", },
        def column TEXT_SLOZ { type: text, optional: true, description: "Text složky dokladu", },
        def column MNPOCETMJ { type: decimal, optional: true, description: "Počet měrných jednotek", },
        def column HDJCENAKC { type: text, optional: true, description: "Jednotková cena v Kč", },
        def column HDCCENAKC { type: text, optional: true, description: "Celková cena v Kč", },
    ]
}

def table QSTRED_DF { description: """Číselník účetních (nákladových) středisek.
""", primaryKey: ["IDSTRED"],
    columns: [
        def column IDSTRED { type: int, isKey: true, description: "Unikátní identifikátor střediska", },
        def column KOD_STR { type: text, optional: true, description: "Kód střediska", search { searchable: true, fuzzy: true, descriptions { cs: ["Hledání střediska podle kódu. Příklad: WHERE KOD_STR = '10'"] } } },
        def column NAZEV_STR { type: text, optional: true, description: "Název střediska", search { searchable: true, fuzzy: true, descriptions { cs: ["Hledání střediska podle názvu. Příklad: WHERE NAZEV_STR COLLATE Latin1_General_CI_AI LIKE '%obchod%'"] } } },
        def column IDXXUKAZMU { type: int, optional: true, description: "FK na ukazatel manažerského účetnictví (QXXUKAZMU.IDXXUKAZMU)", },
    ]
}

def table QTYPDOK { description: """Číselník typů dokladů.
""", primaryKey: ["IDTYPDOK"],
    columns: [
        def column IDTYPDOK { type: int, isKey: true, description: "Unikátní identifikátor typu dokladu", },
        def column TYP_DOK { type: text, optional: true, description: "Kód typu dokladu", search { fuzzy: true } },
        def column NAZEV_TYPDOK { type: text, optional: true, description: "Název typu dokladu", search { fuzzy: true } },
    ]
}

def table QUCETZAP { description: """Účetní zápisy – jednotlivé řádky účetních dokladů s obraty MD/Dal.
""", primaryKey: ["IDUCETZAP"],
    columns: [
        def column IDUCETZAP { type: int, isKey: true, description: "Unikátní identifikátor účetního zápisu", },
        def column IDHDOK { type: int, optional: true, description: "FK na hlavičku účetního dokladu", },
        def column IDSDOK { type: int, optional: true, description: "FK na složku účetního dokladu", },
        def column IDSTRED { type: int, optional: true, description: "FK na účetní středisko (QSTRED_DF.IDSTRED)", },
        def column IDUCTOSN { type: int, optional: true, description: "FK na účet účetní osnovy (QUCTOSN_DF.IDUCTOSN)", },
        def column IDUCTOBD { type: int, optional: true, description: "FK na účetní období (QUCTOBD.IDUCTOBD)", },
        def column UZTEXT { type: text, optional: true, description: "Text účetního zápisu", },
        def column HDOBRAT_MD { type: text, optional: true, description: "Obrat strany Má dáti", },
        def column HDOBRAT_DAL { type: text, optional: true, description: "Obrat strany Dal", },
        def column HDKON_STAV { type: text, optional: true, description: "Účetní hodnota", },
    ]
}

def table QUCTOBD { description: """Číselník účetních období. Každý záznam reprezentuje jedno účetní období (typicky měsíc)
s vazbou na fiskální období, datem prvního a posledního dne.
""", primaryKey: ["IDUCTOBD"],
    columns: [
        def column IDUCTOBD { type: int, isKey: true, description: "Unikátní identifikátor účetního období", },
        def column UCET_OBD { type: text, optional: true, description: "Kód účetního období ve formátu RRRR.MM (např. 2026.04)", search { searchable: true, descriptions { cs: ["Hledání účetního období. Příklad: WHERE UCET_OBD LIKE '%2026%'"] } } },
        def column VLSTAVUO { type: int, optional: true, description: "Stav účetního období (0 = otevřené)", },
        def column dtObd_PrvniDen { type: datetime, optional: true, description: "První den účetního období", },
        def column dtObd_PoslDen { type: datetime, optional: true, description: "Poslední den účetního období", },
    ]
}

def table QUCTOSN_DF { description: """Číselník účtů účetní osnovy.
""", primaryKey: ["IDUCTOSN"],
    columns: [
        def column IDUCTOSN { type: int, isKey: true, description: "Unikátní identifikátor účtu", },
        def column KOD_UCTU { type: text, optional: true, description: "Kód účtu (např. 013, 501001)", search { searchable: true, descriptions { cs: ["Hledání účtu podle kódu. Příklad: WHERE KOD_UCTU LIKE '501%'"] } } },
        def column NAZEV_UCTU { type: text, optional: true, description: "Název účtu", search { searchable: true, descriptions { cs: ["Hledání účtu podle názvu. Příklad: WHERE NAZEV_UCTU COLLATE Latin1_General_CI_AI LIKE '%software%'"] } } },
    ]
}

def table QXXUKAZMU { description: """Číselník ukazatelů manažerského účetnictví. Každý ukazatel je přiřazen ke středisku.
""", primaryKey: ["IDXXUKAZMU"],
    columns: [
        def column IDXXUKAZMU { type: int, isKey: true, description: "Unikátní identifikátor ukazatele", },
        def column KOD_UKAZMU { type: text, optional: true, description: "Kód ukazatele", search { searchable: true, fuzzy: true, descriptions { cs: ["Hledání ukazatele podle kódu. Příklad: WHERE KOD_UKAZMU COLLATE Latin1_General_CI_AI LIKE '%AD%'"] } } },
        def column NAZEV_UKAZMU { type: text, optional: true, description: "Název ukazatele", search { searchable: true, fuzzy: true, descriptions { cs: ["Hledání ukazatele podle názvu. Příklad: WHERE NAZEV_UKAZMU COLLATE Latin1_General_CI_AI LIKE '%majetek%'"] } } },
    ]
}

def table QXXUKAZMUHOD { description: """Hodnoty ukazatelů manažerského účetnictví za účetní období (plán, skutečnost).
""", primaryKey: ["IDXXUKAZMUHOD"],
    columns: [
        def column IDXXUKAZMUHOD { type: int, isKey: true, description: "Unikátní identifikátor záznamu hodnoty", },
        def column IDXXUKAZMU { type: int, optional: true, description: "FK na ukazatel manažerského účetnictví (QXXUKAZMU.IDXXUKAZMU)", },
        def column IDUCTOBD { type: int, optional: true, description: "FK na účetní období (QUCTOBD.IDUCTOBD)", },
        def column HDPLAN { type: text, optional: true, description: "Plánovaná hodnota za období", },
        def column HDSKUT { type: text, optional: true, description: "Skutečná hodnota za období", },
        def column HDPLANKUM { type: text, optional: true, description: "Plánovaná hodnota kumulativně", },
        def column HDSKUTKUM { type: text, optional: true, description: "Skutečná hodnota kumulativně", },
    ]
}

def query ucetni_doklad_detail { description: "Detail účetního dokladu (hlavička + složky) pro daný účetní zápis", language: SQL, sourceText: """WITH z AS
  (SELECT r.IDHDOK, r.IDSDOK FROM QUCETZAP r WHERE r.IDUCETZAP = {id_ucetniho_zapisu})
SELECT s.IDSDOK,
       t.NAZEV_TYPDOK,
       d.CIS_DOK,
       d.DTZDANITPLN,
       d.IDSUBJEKT,
       s.ZAK_SDOK,
       d.TEXTPOZN,
       s.PORADI_DOK,
       s.VLTYP_SLOZ,
       s.KOD_POHYB,
       s.SLOZKA_IDENT,
       s.NAZEV_ZBOZI,
       s.TEXT_SLOZ,
       s.MNPOCETMJ,
       s.HDJCENAKC,
       s.HDCCENAKC
FROM QHDOK d
LEFT JOIN QTYPDOK t ON t.IDTYPDOK = d.IDTYPDOK
LEFT JOIN QSDOK s ON s.IDSDOK = (SELECT IDSDOK FROM z)
WHERE d.IDHDOK = (SELECT IDHDOK FROM z)
ORDER BY s.PORADI_DOK""", search { patterns: ["(detail|zobraz|ukaž|ukaz) (účetní |ucetni |)(doklad|dokladu) (pro |)(zápis|zapis|záznam|zaznam) {id_ucetniho_zapisu}"], examples: ["Detail dokladu pro zápis 12345"] }
    parameters: [
        { name: id_ucetniho_zapisu, type: int, label: "IDUCETZAP účetního zápisu" },
    ]
}

def query ucetni_zapisy_agregace_strediska { description: "Součty účetních zápisů po účtech pro středisko za období", language: SQL, sourceText: """SELECT MIN(z.IDUCETZAP) AS IDUCETZAP,
       o.UCET_OBD,
       s.KOD_STR,
       s.NAZEV_STR,
       u.KOD_UCTU,
       u.NAZEV_UCTU,
       SUM(z.HDKON_STAV) AS UCETNI_HODNOTA,
       -SUM(z.HDKON_STAV) AS MU_HODNOTA
FROM QUCETZAP z
JOIN QSTRED_DF s ON s.IDSTRED = z.IDSTRED
JOIN QUCTOBD o ON o.IDUCTOBD = z.IDUCTOBD
JOIN QUCTOSN_DF u ON u.IDUCTOSN = z.IDUCTOSN
WHERE (s.KOD_STR COLLATE Latin1_General_CI_AI LIKE CONCAT({nazev_strediska}, '%')
   OR s.NAZEV_STR COLLATE Latin1_General_CI_AI LIKE CONCAT('%', {nazev_strediska}, '%'))
  AND o.UCET_OBD LIKE CONCAT('%', {obdobi}, '%')
  AND substring(u.KOD_UCTU,1,1) in ('5','6','8','9')
GROUP BY z.IDUCTOBD, z.IDUCTOSN, z.IDSTRED,
         o.UCET_OBD, s.KOD_STR, s.NAZEV_STR,
         u.KOD_UCTU, u.NAZEV_UCTU
ORDER BY SUM(z.HDKON_STAV) DESC""", search { patterns: ["(vypiš|vypis|ukaž|ukaz|zobraz) (účetní |ucetni |)(záznamy|zaznamy|zápisy|zapisy|pohyby) (pro |)(středisko|stredisko) {nazev_strediska} za (období|obdobi) {obdobi} podle (účetní hodnoty|ucetni hodnoty)", "(vypiš|vypis|ukaž|ukaz|zobraz) (účetní |ucetni |)(záznamy|zaznamy|zápisy|zapisy|pohyby) (pro |)(středisko|stredisko) {nazev_strediska} za (období|obdobi) {obdobi}"], examples: ["Vypiš účetní záznamy pro středisko DF ADNAK za období 2026.03 podle účetní hodnoty"] }
    parameters: [
        { name: nazev_strediska, type: varchar, label: "Název nebo kód střediska" },
        { name: obdobi, type: varchar, label: "Účetní období (RRRR.MM)" },
    ]
}

def query ucetni_zapisy_agregace_uctu { description: "Součty účetních zápisů po střediscích pro účet za období", language: SQL, sourceText: """SELECT MIN(z.IDUCETZAP) AS IDUCETZAP,
       o.UCET_OBD,
       u.KOD_UCTU,
       u.NAZEV_UCTU,
       s.KOD_STR,
       s.NAZEV_STR,
       SUM(z.HDKON_STAV) AS UCETNI_HODNOTA,
       -SUM(z.HDKON_STAV) AS MU_HODNOTA
FROM QUCETZAP z
JOIN QUCTOSN_DF u ON u.IDUCTOSN = z.IDUCTOSN
JOIN QUCTOBD o ON o.IDUCTOBD = z.IDUCTOBD
JOIN QSTRED_DF s ON s.IDSTRED = z.IDSTRED
WHERE (u.KOD_UCTU COLLATE Latin1_General_CI_AI LIKE CONCAT({nazev_uctu}, '%')
   OR u.NAZEV_UCTU COLLATE Latin1_General_CI_AI LIKE CONCAT('%', {nazev_uctu}, '%'))
  AND o.UCET_OBD LIKE CONCAT('%', {obdobi}, '%')
  AND substring(u.KOD_UCTU,1,1) in ('5','6','8','9')
GROUP BY z.IDUCTOBD, z.IDUCTOSN, z.IDSTRED,
         o.UCET_OBD, u.KOD_UCTU, u.NAZEV_UCTU,
         s.KOD_STR, s.NAZEV_STR
ORDER BY SUM(z.HDKON_STAV) DESC""", search { patterns: ["(vypiš|vypis|ukaž|ukaz|zobraz) (účetní |ucetni |)(záznamy|zaznamy|zápisy|zapisy|pohyby) (pro |)(účet|ucet) {nazev_uctu} za (období|obdobi) {obdobi} podle (účetní hodnoty|ucetni hodnoty)", "(vypiš|vypis|ukaž|ukaz|zobraz) (účetní |ucetni |)(záznamy|zaznamy|zápisy|zapisy|pohyby) (pro |)(účet|ucet) {nazev_uctu} za (období|obdobi) {obdobi}"], examples: ["Vypiš účetní záznamy pro účet 518032 za období 2026.03 podle účetní hodnoty"] }
    parameters: [
        { name: nazev_uctu, type: varchar, label: "Kód nebo název účtu" },
        { name: obdobi, type: varchar, label: "Účetní období (RRRR.MM)" },
    ]
}

def query ucetni_zapisy_agregace_ukazatele { description: "Součty účetních zápisů po účtech pro ukazatel MÚ za období", language: SQL, sourceText: """SELECT MIN(z.IDUCETZAP) AS IDUCETZAP,
       o.UCET_OBD,
       mu.KOD_UKAZMU,
       mu.NAZEV_UKAZMU,
       u.KOD_UCTU,
       u.NAZEV_UCTU,
       SUM(z.HDKON_STAV) AS UCETNI_HODNOTA,
       -SUM(z.HDKON_STAV) AS MU_HODNOTA
FROM QUCETZAP z
JOIN QSTRED_DF s ON s.IDSTRED = z.IDSTRED
JOIN QXXUKAZMU mu ON mu.IDXXUKAZMU = s.IDXXUKAZMU
JOIN QUCTOBD o ON o.IDUCTOBD = z.IDUCTOBD
JOIN QUCTOSN_DF u ON u.IDUCTOSN = z.IDUCTOSN
WHERE (mu.KOD_UKAZMU COLLATE Latin1_General_CI_AI LIKE CONCAT({nazev_ukazatele}, '%')
   OR mu.NAZEV_UKAZMU COLLATE Latin1_General_CI_AI LIKE CONCAT('%', {nazev_ukazatele}, '%'))
  AND o.UCET_OBD LIKE CONCAT('%', {obdobi}, '%')
  AND substring(u.KOD_UCTU,1,1) in ('5','6','8','9')
GROUP BY z.IDUCTOBD, z.IDUCTOSN, z.IDSTRED,
         o.UCET_OBD, mu.KOD_UKAZMU, mu.NAZEV_UKAZMU,
         u.KOD_UCTU, u.NAZEV_UCTU
ORDER BY SUM(z.HDKON_STAV) DESC""", search { patterns: ["(vypiš|vypis|ukaž|ukaz|zobraz) (účetní |ucetni |)(záznamy|zaznamy|zápisy|zapisy|pohyby) (pro |)(ukazatel|ukazatele) {nazev_ukazatele} za (období|obdobi) {obdobi}"], examples: ["Vypiš účetní záznamy pro ukazatel VY KANCELAR za období 2026.03"] }
    parameters: [
        { name: nazev_ukazatele, type: varchar, label: "Kód nebo název ukazatele MÚ" },
        { name: obdobi, type: varchar, label: "Účetní období (RRRR.MM)" },
    ]
}

def query ucetni_zapisy_detail_agregace { description: "Detail účetních zápisů pro kombinaci období+účet+středisko z agregovaného řádku", language: SQL, sourceText: """SELECT z.IDUCETZAP,
       o.UCET_OBD,
       u.KOD_UCTU,
       u.NAZEV_UCTU,
       s.KOD_STR,
       s.NAZEV_STR,
       z.HDKON_STAV AS UCETNI_HODNOTA,
       -z.HDKON_STAV AS MU_HODNOTA,
       d.CIS_DOK,
       z.UZTEXT,
       d.SLOZKA_IDENT
FROM QUCETZAP z
JOIN QUCTOBD o ON o.IDUCTOBD = z.IDUCTOBD
JOIN QUCTOSN_DF u ON u.IDUCTOSN = z.IDUCTOSN
JOIN QSTRED_DF s ON s.IDSTRED = z.IDSTRED
LEFT JOIN QSDOK d ON d.IDSDOK = z.IDSDOK
WHERE z.IDUCTOBD = (SELECT TOP 1 r.IDUCTOBD FROM QUCETZAP r WHERE r.IDUCETZAP = {id_ucetniho_zapisu})
  AND z.IDUCTOSN = (SELECT TOP 1 r.IDUCTOSN FROM QUCETZAP r WHERE r.IDUCETZAP = {id_ucetniho_zapisu})
  AND z.IDSTRED = (SELECT TOP 1 r.IDSTRED FROM QUCETZAP r WHERE r.IDUCETZAP = {id_ucetniho_zapisu})
ORDER BY z.HDKON_STAV DESC""", search { patterns: ["(detail|rozpad|rozbal) (účetních |ucetnich |)(zápisů|zapisu|agregace|záznamu|zaznamu) {id_ucetniho_zapisu}"], examples: ["Detail účetních zápisů 12345"] }
    parameters: [
        { name: id_ucetniho_zapisu, type: int, label: "IDUCETZAP z agregovaného řádku" },
    ]
}


{
  "consumer": "hebe",
  "shape": "chat-stream-notool",
  "method": "POST",
  "path": "/v1/chat/completions",
  "headers": {
    "Content-Type": "application/json",
    "Authorization": "Bearer __REDACTED_GATEWAY_KEY__",
    "X-Cost-Center": "hebe/__instance_id__",
    "X-Turn-Ref": "__turn_or_job_id__",
    "traceparent": "00-__trace__-__span__-01"
  },
  "requestBody": {
    "model": "gw-model",
